generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model School {
  id                       String                    @id @default(uuid())
  name                     String
  curriculumId             String
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  primaryColor             String                    @default("#f59e0b")
  secondaryColor           String                    @default("#1e293b")
  whatsappCredits          Int                       @default(0)
  activityLogs             ActivityLog[]
  assessments              Assessment[]
  classes                  Class[]
  classEnrollments         ClassEnrollment[]
  creditTransactions       CreditTransaction[]
  curricula                Curriculum[]              @relation("SchoolCurriculum")
  Exam                     Exam[]
  feedbacks                Feedback[]
  grades                   Grade[]
  gradeSubjects            GradeSubject[]
  lessons                  Lesson[]
  ParentStudent            ParentStudent[]
  Question                 Question[]
  curriculum               Curriculum                @relation("SchoolPrimaryCurriculum", fields: [curriculumId], references: [id])
  studentSubjects          StudentSubject[]
  subjects                 Subject[]
  subscription             Subscription?
  subscriptionTransactions SubscriptionTransaction[]
  terms                    Term[]
  topics                   Topic[]
  users                    Profile[]
}

model Profile {
  id                                              String            @id @default(uuid())
  email                                           String            @unique
  name                                            String?
  role                                            Role
  schoolId                                        String?
  curriculumId                                    String
  createdAt                                       DateTime          @default(now())
  updatedAt                                       DateTime          @updatedAt
  phone                                           String?
  primaryColor                                    String            @default("#f59e0b")
  secondaryColor                                  String            @default("#1e293b")
  activityLogs                                    ActivityLog[]
  assessments                                     Assessment[]      @relation("StudentAssessments")
  taughtClasses                                   Class[]           @relation("TeacherClasses")
  classEnrollments                                ClassEnrollment[]
  Exam                                            Exam[]
  ownedGradeSubjects                              GradeSubject[]    @relation("ProfileToGradeSubject")
  notifications                                   Notification[]
  ParentStudent_ParentStudent_parentIdToprofiles  ParentStudent[]   @relation("ParentStudent_parentIdToprofiles")
  ParentStudent_ParentStudent_studentIdToprofiles ParentStudent[]   @relation("ParentStudent_studentIdToprofiles")
  studentSubjects                                 StudentSubject[]
  subscription                                    Subscription?     @relation("ProfileSubscription")
  curriculum                                      Curriculum        @relation(fields: [curriculumId], references: [id])
  school                                          School?           @relation(fields: [schoolId], references: [id])
  gradeSubjectsTaught                             GradeSubject[]    @relation("TeacherGradeSubjects")
  selectedSubjects                                GradeSubject[]    @relation("UserSelectedSubjects")

  @@index([schoolId])
  @@index([curriculumId])
  @@map("profiles")
}

model ParentStudent {
  id        String   @id @default(uuid())
  parentId  String
  studentId String
  schoolId  String?
  createdAt DateTime @default(now())
  parent    Profile  @relation("ParentStudent_parentIdToprofiles", fields: [parentId], references: [id])
  school    School?  @relation(fields: [schoolId], references: [id])
  student   Profile  @relation("ParentStudent_studentIdToprofiles", fields: [studentId], references: [id])

  @@unique([parentId, studentId])
  @@index([parentId])
  @@index([studentId])
  @@index([schoolId])
}

model Curriculum {
  id             String    @id @default(uuid())
  name           String
  schoolId       String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  subjectLabel   String    @default("Subject")
  termLabel      String    @default("Term")
  yearLabel      String    @default("Year")
  type           String    @default("generic")
  school         School?   @relation("SchoolCurriculum", fields: [schoolId], references: [id])
  grades         Grade[]
  primarySchools School[]  @relation("SchoolPrimaryCurriculum")
  subjects       Subject[]
  users          Profile[]

  @@index([schoolId])
}

model Grade {
  id            String         @id @default(uuid())
  level         Int
  slug          String
  displayName   String
  shortName     String?
  curriculumId  String
  schoolId      String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  classes       Class[]
  curriculum    Curriculum     @relation(fields: [curriculumId], references: [id])
  school        School?        @relation(fields: [schoolId], references: [id])
  gradeSubjects GradeSubject[]
  terms         Term[]

  @@unique([curriculumId, level])
  @@index([schoolId])
  @@index([curriculumId])
}

model Term {
  id          String    @id @default(uuid())
  index       Int
  displayName String
  gradeId     String
  schoolId    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  endDate     DateTime?
  startDate   DateTime?
  Exam        Exam[]
  grade       Grade     @relation(fields: [gradeId], references: [id])
  school      School?   @relation(fields: [schoolId], references: [id])
  topics      Topic[]

  @@unique([gradeId, index])
  @@index([schoolId])
}

model Subject {
  id            String         @id @default(uuid())
  name          String
  curriculumId  String
  schoolId      String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  gradeSubjects GradeSubject[]
  curriculum    Curriculum     @relation(fields: [curriculumId], references: [id])
  school        School?        @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
  @@index([curriculumId])
}

model Topic {
  id             String       @id @default(uuid())
  title          String
  gradeSubjectId String
  termId         String
  schoolId       String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  description    String?
  weekNumber     Int?
  assessments    Assessment[]
  lessons        Lesson[]
  Question       Question[]
  gradeSubject   GradeSubject @relation(fields: [gradeSubjectId], references: [id])
  school         School?      @relation(fields: [schoolId], references: [id])
  term           Term         @relation(fields: [termId], references: [id])

  @@index([schoolId])
}

model Class {
  id          String            @id @default(uuid())
  name        String
  gradeId     String
  schoolId    String?
  teacherId   String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  grade       Grade             @relation(fields: [gradeId], references: [id])
  school      School?           @relation(fields: [schoolId], references: [id])
  teacher     Profile           @relation("TeacherClasses", fields: [teacherId], references: [id])
  enrollments ClassEnrollment[]
  Exam        Exam[]

  @@index([schoolId])
}

model ClassEnrollment {
  id        String   @id @default(uuid())
  classId   String?
  studentId String
  schoolId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  class     Class?   @relation(fields: [classId], references: [id])
  school    School   @relation(fields: [schoolId], references: [id])
  student   Profile  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model StudentSubject {
  id             String           @id @default(uuid())
  studentId      String
  gradeSubjectId String
  schoolId       String
  status         EnrollmentStatus @default(APPROVED)
  isCompulsory   Boolean          @default(true)
  gradeSubject   GradeSubject     @relation(fields: [gradeSubjectId], references: [id], onDelete: Cascade)
  school         School           @relation(fields: [schoolId], references: [id])
  student        Profile          @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, gradeSubjectId])
}

model Assessment {
  id             String         @id @default(uuid())
  type           AssessmentType
  studentId      String
  gradeSubjectId String
  topicId        String?
  schoolId       String?
  score          Float?
  maxScore       Float?
  comments       String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  examId         String?
  Exam           Exam?          @relation(fields: [examId], references: [id])
  gradeSubject   GradeSubject   @relation(fields: [gradeSubjectId], references: [id])
  school         School?        @relation(fields: [schoolId], references: [id])
  student        Profile        @relation("StudentAssessments", fields: [studentId], references: [id])
  topic          Topic?         @relation(fields: [topicId], references: [id])
  feedbacks      Feedback[]

  @@index([schoolId])
}

model Lesson {
  id          String   @id @default(uuid())
  title       String
  content     String?
  topicId     String
  schoolId    String?
  aiContent   Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  videoScript String?
  school      School?  @relation(fields: [schoolId], references: [id])
  topic       Topic    @relation(fields: [topicId], references: [id])
  quiz        Quiz?

  @@unique([topicId, schoolId])
}

model Quiz {
  id            String         @id @default(uuid())
  lessonId      String         @unique
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  lesson        Lesson         @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  quizQuestions QuizQuestion[]
}

model Question {
  id            String           @id @default(uuid())
  text          String
  options       Json
  correctAnswer String
  explanation   String?
  category      QuestionCategory @default(PRACTICE)
  createdAt     DateTime         @default(now())
  points        Int              @default(1)
  schoolId      String?
  topicId       String
  updatedAt     DateTime         @updatedAt
  examLinks     ExamQuestion[]
  school        School?          @relation(fields: [schoolId], references: [id])
  topic         Topic            @relation(fields: [topicId], references: [id], onDelete: Cascade)
  quizLinks     QuizQuestion[]
}

model Exam {
  id             String           @id @default(uuid())
  title          String
  type           AssessmentType
  duration       Int              @default(60)
  status         ExamStatus       @default(DRAFT)
  schoolId       String
  classId        String
  termId         String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  creatorId      String
  endTime        DateTime?
  startTime      DateTime?
  assessments    Assessment[]
  class          Class            @relation(fields: [classId], references: [id])
  profiles       Profile          @relation(fields: [creatorId], references: [id])
  school         School           @relation(fields: [schoolId], references: [id])
  term           Term             @relation(fields: [termId], references: [id])
  questions      ExamQuestion[]
  ExamSubmission ExamSubmission[]
}

model QuizQuestion {
  id         String   @id @default(uuid())
  quizId     String
  questionId String
  order      Int
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  quiz       Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@unique([quizId, questionId])
}

model ExamQuestion {
  id         String   @id @default(uuid())
  examId     String
  questionId String
  order      Int
  exam       Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([examId, questionId])
}

model Feedback {
  id           String     @id @default(uuid())
  assessmentId String
  schoolId     String?
  message      String?
  whatsappSid  String?
  sentAt       DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  assessment   Assessment @relation(fields: [assessmentId], references: [id])
  school       School?    @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
}

model GradeSubject {
  id              String           @id @default(uuid())
  gradeId         String
  subjectId       String
  schoolId        String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  profileId       String?
  assessments     Assessment[]
  grade           Grade            @relation(fields: [gradeId], references: [id])
  profile         Profile?         @relation("ProfileToGradeSubject", fields: [profileId], references: [id])
  school          School?          @relation(fields: [schoolId], references: [id])
  subject         Subject          @relation(fields: [subjectId], references: [id])
  studentSubjects StudentSubject[]
  topics          Topic[]
  teachers        Profile[]        @relation("TeacherGradeSubjects")
  selectedByUsers Profile[]        @relation("UserSelectedSubjects")

  @@unique([gradeId, subjectId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  message   String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      Profile  @relation(fields: [userId], references: [id])

  @@index([userId, read])
}

model Subscription {
  id                String            @id @default(uuid())
  schoolId          String            @unique
  plan              String
  status            String
  stripeCustomerId  String?           @unique
  currentPeriodEnd  DateTime
  profileId         String?           @unique
  amountNGN         Int?
  createdAt         DateTime          @default(now())
  paidAt            DateTime?
  paystackReference String?           @unique
  planId            String?
  updatedAt         DateTime          @default(now()) @updatedAt
  subPlan           SubscriptionPlan? @relation(fields: [planId], references: [id])
  profile           Profile?          @relation("ProfileSubscription", fields: [profileId], references: [id])
  school            School            @relation(fields: [schoolId], references: [id])

  @@index([status])
  @@index([currentPeriodEnd])
}

model Invitation {
  id           String    @id @default(uuid())
  email        String
  role         Role
  schoolId     String?
  token        String    @unique
  expiresAt    DateTime
  acceptedAt   DateTime?
  invitedBy    String
  createdAt    DateTime  @default(now())
  curriculumId String

  @@index([token])
  @@index([email])
}

model ActivityLog {
  id          String       @id @default(uuid())
  schoolId    String
  actorId     String
  actorName   String?
  actorRole   String?
  type        ActivityType
  title       String
  description String
  metadata    Json?
  createdAt   DateTime     @default(now())
  actor       Profile      @relation(fields: [actorId], references: [id])
  school      School       @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
  @@index([actorId])
  @@index([createdAt])
}

model CreditTransaction {
  id          String    @id @default(uuid())
  schoolId    String
  packageId   String
  credits     Int
  amountNGN   Int
  amountKobo  Int
  reference   String    @unique
  status      TxStatus  @default(PENDING)
  initiatedBy String
  paidAt      DateTime?
  createdAt   DateTime  @default(now())
  school      School    @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
  @@index([reference])
}

model SubscriptionPlan {
  id                       String                    @id @default(uuid())
  name                     String
  slug                     String                    @unique
  priceNGN                 Int
  priceKobo                Int
  priceUSD                 Float
  durationDays             Int
  description              String
  features                 String[]
  popular                  Boolean                   @default(false)
  active                   Boolean                   @default(true)
  sortOrder                Int                       @default(0)
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  subscriptions            Subscription[]
  subscriptionTransactions SubscriptionTransaction[]

  @@index([active])
  @@index([sortOrder])
}

model SubscriptionTransaction {
  id          String           @id @default(uuid())
  schoolId    String
  planId      String
  planName    String
  amountNGN   Int
  amountKobo  Int
  reference   String           @unique
  status      TxStatus         @default(PENDING)
  initiatedBy String
  paidAt      DateTime?
  createdAt   DateTime         @default(now())
  plan        SubscriptionPlan @relation(fields: [planId], references: [id])
  school      School           @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
  @@index([status])
  @@index([createdAt])
}

model CreditPackage {
  id          String   @id @default(uuid())
  name        String
  credits     Int
  priceNGN    Int
  priceKobo   Int
  priceUSD    Float
  description String
  popular     Boolean  @default(false)
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([active])
}

model ClassPerformance {
  id           String @id
  classId      String
  examId       String
  averageScore Float
  passRate     Float
}

model ExamSubmission {
  id               String             @id
  examId           String
  studentId        String
  classId          String
  answers          Json
  score            Int?
  total            Int?
  status           SubmissionStatus   @default(SUBMITTED)
  gradedAt         DateTime?
  createdAt        DateTime           @default(now())
  Exam             Exam               @relation(fields: [examId], references: [id])
  SubmissionAnswer SubmissionAnswer[]
}

model SubmissionAnswer {
  id             String         @id
  submissionId   String
  questionId     String
  selected       String
  correct        Boolean
  score          Int
  ExamSubmission ExamSubmission @relation(fields: [submissionId], references: [id])
}

enum TxStatus {
  PENDING
  SUCCESS
  FAILED
}

enum ActivityType {
  ASSESSMENT_CREATED
  ASSESSMENT_GRADED
  STUDENT_ENROLLED
  STUDENT_ASSIGNED
  TEACHER_ASSIGNED
  USER_INVITED
  USER_DEACTIVATED
  USER_DELETED
  USER_REACTIVATED
  CLASS_CREATED
  SETTINGS_UPDATED
  CURRICULUM_UPDATED
  TERM_DATES_UPDATED
  WHATSAPP_SENT
  LOGIN
  LOGOUT
  REPORT_GENERATED
}

enum Role {
  SUPER_ADMIN
  SCHOOL_ADMIN
  TEACHER
  STUDENT
  PARENT
  INDIVIDUAL_LEARNER
}

enum AssessmentType {
  TOPIC_BASED
  WEEKLY
  TERMLY
  YEARLY
  MID_TERM
  END_OF_TERM
}

enum EnrollmentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum QuestionCategory {
  PRACTICE
  EXAM
}

enum ExamStatus {
  DRAFT
  PUBLISHED
  COMPLETED
  ONGOING
  SCHEDULED
}

enum SubmissionStatus {
  SUBMITTED
  GRADED
}
