generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model School {
  id           String     @id @default(uuid())
  name         String
  curriculumId String
  curriculum   Curriculum @relation("SchoolPrimaryCurriculum", fields: [curriculumId], references: [id])

  whatsappCredits Int @default(0)

  // Relations
  users            Profile[]
  classes          Class[]
  curricula        Curriculum[]      @relation("SchoolCurriculum")
  grades           Grade[]
  terms            Term[]
  subjects         Subject[]
  topics           Topic[]
  classEnrollments ClassEnrollment[]
  feedbacks        Feedback[]
  gradeSubjects    GradeSubject[]
  schoolLessons    SchoolLesson[]

  ParentStudent            ParentStudent[]
  subscription             Subscription?
  activityLogs             ActivityLog[]
  assessments              Assessment[]
  primaryColor             String                    @default("#f59e0b")
  secondaryColor           String                    @default("#1e293b")
  studentSubjects          StudentSubject[]
  creditTransactions       CreditTransaction[]
  subscriptionTransactions SubscriptionTransaction[]

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  Question     Question[]
  Exam         Exam[]
  GlobalLesson GlobalLesson[]
}

model Profile {
  id           String  @id @default(uuid())
  email        String  @unique
  name         String?
  role         Role
  phone        String?
  schoolId     String?
  curriculumId String

  // Branding
  primaryColor   String @default("#f59e0b")
  secondaryColor String @default("#1e293b")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  school     School?    @relation(fields: [schoolId], references: [id])
  curriculum Curriculum @relation(fields: [curriculumId], references: [id])

  // Classes
  taughtClasses    Class[]           @relation("TeacherClasses")
  classEnrollments ClassEnrollment[]
  studentSubjects  StudentSubject[]

  // Assessments
  assessments Assessment[] @relation("StudentAssessments")

  // Grade subjects
  gradeSubjectsTaught GradeSubject[] @relation("TeacherGradeSubjects")
  selectedSubjects    GradeSubject[] @relation("UserSelectedSubjects")
  ownedGradeSubjects  GradeSubject[] @relation("ProfileToGradeSubject")

  // Parent ↔ Student
  ParentStudent_ParentStudent_parentIdToprofiles  ParentStudent[] @relation("ParentStudent_parentIdToprofiles")
  ParentStudent_ParentStudent_studentIdToprofiles ParentStudent[] @relation("ParentStudent_studentIdToprofiles")

  // Notifications
  notifications Notification[]

  subscription Subscription? @relation("ProfileSubscription")
  activityLogs ActivityLog[]
  createdExams Exam[]        @relation("ExamCreator")

  @@index([schoolId])
  @@index([curriculumId])
  @@map("profiles")
}

model ParentStudent {
  id        String   @id @default(uuid())
  parentId  String
  studentId String
  schoolId  String?
  createdAt DateTime @default(now())

  parent  Profile @relation("ParentStudent_parentIdToprofiles", fields: [parentId], references: [id])
  student Profile @relation("ParentStudent_studentIdToprofiles", fields: [studentId], references: [id])
  school  School? @relation(fields: [schoolId], references: [id])

  @@unique([parentId, studentId])
  @@index([parentId])
  @@index([studentId])
  @@index([schoolId])
}

// ---------------- Curriculum Hierarchy ----------------

model Curriculum {
  id             String    @id @default(uuid())
  name           String
  type           String    @default("generic") // 'nigerian' | 'british' | 'american' | 'generic'
  schoolId       String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  subjectLabel   String    @default("Subject")
  termLabel      String    @default("Term")
  yearLabel      String    @default("Year")
  school         School?   @relation("SchoolCurriculum", fields: [schoolId], references: [id])
  grades         Grade[]
  primarySchools School[]  @relation("SchoolPrimaryCurriculum")
  subjects       Subject[]
  users          Profile[]

  @@index([schoolId])
}

model Grade {
  id            String         @id @default(uuid())
  level         Int
  slug          String
  displayName   String
  shortName     String?
  curriculumId  String
  schoolId      String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  classes       Class[]
  curriculum    Curriculum     @relation(fields: [curriculumId], references: [id])
  school        School?        @relation(fields: [schoolId], references: [id])
  gradeSubjects GradeSubject[]
  terms         Term[]

  @@unique([curriculumId, level])
  @@index([schoolId])
  @@index([curriculumId])
}

model Term {
  id          String    @id @default(uuid())
  index       Int
  displayName String
  gradeId     String
  schoolId    String?
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  grade       Grade     @relation(fields: [gradeId], references: [id])
  school      School?   @relation(fields: [schoolId], references: [id])
  topics      Topic[]
  Exam        Exam[]

  @@unique([gradeId, index])
  @@index([schoolId])
}

model Subject {
  id            String         @id @default(uuid())
  name          String
  curriculumId  String
  schoolId      String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  gradeSubjects GradeSubject[]
  ownershipType String         @default("GLOBAL")
  curriculum    Curriculum     @relation(fields: [curriculumId], references: [id])
  school        School?        @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
  @@index([curriculumId])
}

model Topic {
  id             String         @id @default(uuid())
  title          String
  gradeSubjectId String
  termId         String
  schoolId       String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  description    String?
  weekNumber     Int?
  assessments    Assessment[]
  gradeSubject   GradeSubject   @relation(fields: [gradeSubjectId], references: [id])
  school         School?        @relation(fields: [schoolId], references: [id])
  term           Term           @relation(fields: [termId], references: [id])
  Question       Question[]
  GlobalLesson   GlobalLesson[]
  SchoolLesson   SchoolLesson[]

  @@index([schoolId])
}

model Class {
  id          String            @id @default(uuid())
  name        String
  gradeId     String
  schoolId    String?
  teacherId   String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  grade       Grade             @relation(fields: [gradeId], references: [id])
  school      School?           @relation(fields: [schoolId], references: [id])
  teacher     Profile           @relation("TeacherClasses", fields: [teacherId], references: [id])
  enrollments ClassEnrollment[]
  Exam        Exam[]

  @@index([schoolId])
}

model ClassEnrollment {
  id        String   @id @default(uuid())
  classId   String?
  studentId String
  schoolId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  class   Class?  @relation(fields: [classId], references: [id])
  school  School  @relation(fields: [schoolId], references: [id])
  student Profile @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model StudentSubject {
  id             String           @id @default(uuid())
  studentId      String
  gradeSubjectId String
  schoolId       String
  status         EnrollmentStatus @default(APPROVED)
  isCompulsory   Boolean          @default(true)

  student      Profile      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  gradeSubject GradeSubject @relation(fields: [gradeSubjectId], references: [id], onDelete: Cascade)
  school       School       @relation(fields: [schoolId], references: [id])

  @@unique([studentId, gradeSubjectId])
}

model Assessment {
  id             String         @id @default(uuid())
  type           AssessmentType
  studentId      String
  gradeSubjectId String
  topicId        String?
  schoolId       String?
  score          Float?
  maxScore       Float?
  comments       String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  gradeSubject   GradeSubject   @relation(fields: [gradeSubjectId], references: [id])
  school         School?        @relation(fields: [schoolId], references: [id])
  student        Profile        @relation("StudentAssessments", fields: [studentId], references: [id])
  topic          Topic?         @relation(fields: [topicId], references: [id])
  feedbacks      Feedback[]
  Exam           Exam?          @relation(fields: [examId], references: [id])
  examId         String?

  @@index([schoolId])
}

model GlobalLesson {
  id String @id @default(uuid())

  title    String
  topicId  String
  schoolId String? // null = global version

  aiContent Json?

  videoScript String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school        School?        @relation(fields: [schoolId], references: [id])
  topic         Topic          @relation(fields: [topicId], references: [id])
  quiz          Quiz?
  schoolLessons SchoolLesson[]

  @@unique([topicId, schoolId])
  @@index([schoolId])
  @@index([topicId])
}

model SchoolLesson {
  id String @id @default(cuid())

  topicId  String
  schoolId String

  globalLessonId String
  globalLesson   GlobalLesson @relation(fields: [globalLessonId], references: [id])

  // ✅ REQUIRED RELATIONS
  school School @relation(fields: [schoolId], references: [id])
  topic  Topic  @relation(fields: [topicId], references: [id])

  // Customization
  customContent Json?
  customQuiz    Json?

  status       LessonStatus @default(DRAFT)
  isCustomized Boolean      @default(false)

  // Versioning
  versions LessonVersion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([topicId, schoolId])
  @@index([schoolId])
  @@index([topicId])
}

model LessonVersion {
  id String @id @default(cuid())

  schoolLessonId String
  schoolLesson   SchoolLesson @relation(fields: [schoolLessonId], references: [id])

  version Int

  content Json

  createdAt DateTime @default(now())

  @@index([schoolLessonId])
}

model Quiz {
  id       String @id @default(uuid())
  lessonId String @unique

  lesson GlobalLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  quizQuestions QuizQuestion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 1. The Independent Question Bank

model Question {
  id            String           @id @default(uuid())
  text          String
  options       Json // Array of strings
  correctAnswer String
  explanation   String?
  points        Int              @default(1)
  category      QuestionCategory @default(PRACTICE)

  topicId  String
  schoolId String? // null = Global, UUID = School Custom

  topic  Topic   @relation(fields: [topicId], references: [id], onDelete: Cascade)
  school School? @relation(fields: [schoolId], references: [id])

  quizLinks QuizQuestion[]
  examLinks ExamQuestion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 2. The High-Stakes Exam Model
model Exam {
  id        String         @id @default(uuid())
  title     String
  type      AssessmentType // MID_TERM, END_OF_TERM
  duration  Int            @default(60) // minutes
  status    ExamStatus     @default(DRAFT)
  creatorId String
  schoolId  String
  classId   String
  termId    String
  creator   Profile        @relation("ExamCreator", fields: [creatorId], references: [id])
  startTime DateTime?
  endTime   DateTime?

  questions   ExamQuestion[]
  assessments Assessment[] // The actual student results
  submissions ExamSubmission[]

  school School @relation(fields: [schoolId], references: [id])
  class  Class  @relation(fields: [classId], references: [id])
  term   Term   @relation(fields: [termId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ExamSubmission {
  id String @id @default(cuid())

  examId    String
  studentId String
  classId   String

  answers Json // [{questionId, selectedAnswer}]

  score  Int? // computed after grading
  total  Int?
  status SubmissionStatus @default(SUBMITTED)

  gradedAt  DateTime?
  createdAt DateTime  @default(now())

  exam             Exam               @relation(fields: [examId], references: [id])
  SubmissionAnswer SubmissionAnswer[]
}

model SubmissionAnswer {
  id String @id @default(cuid())

  submissionId String
  questionId   String

  selected String
  correct  Boolean
  score    Int

  submission ExamSubmission @relation(fields: [submissionId], references: [id])
}

// 3. Junction Tables
model QuizQuestion {
  id         String @id @default(uuid())
  quizId     String
  questionId String
  order      Int

  quiz     Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([quizId, questionId])
}

model ExamQuestion {
  id         String @id @default(uuid())
  examId     String
  questionId String
  order      Int

  exam     Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([examId, questionId])
}

model ClassPerformance {
  id      String @id @default(cuid())
  classId String
  examId  String

  averageScore Float
  passRate     Float
}

model Feedback {
  id           String     @id @default(uuid())
  assessmentId String
  schoolId     String?
  message      String?
  whatsappSid  String?
  sentAt       DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  assessment   Assessment @relation(fields: [assessmentId], references: [id])
  school       School?    @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
}

model GradeSubject {
  id              String           @id @default(uuid())
  gradeId         String
  subjectId       String
  schoolId        String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  profileId       String?
  assessments     Assessment[]
  grade           Grade            @relation(fields: [gradeId], references: [id])
  profile         Profile?         @relation("ProfileToGradeSubject", fields: [profileId], references: [id])
  school          School?          @relation(fields: [schoolId], references: [id])
  subject         Subject          @relation(fields: [subjectId], references: [id])
  topics          Topic[]
  teachers        Profile[]        @relation("TeacherGradeSubjects")
  selectedByUsers Profile[]        @relation("UserSelectedSubjects")
  studentSubjects StudentSubject[]

  @@unique([gradeId, subjectId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  message   String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      Profile  @relation(fields: [userId], references: [id])

  @@index([userId, read])
}

model Subscription {
  id                String    @id @default(uuid())
  schoolId          String    @unique
  plan              String
  profileId         String?   @unique
  status            String
  // ── Keep existing Stripe fields for future Stripe migration ──
  stripeCustomerId  String?   @unique
  currentPeriodEnd  DateTime
  // ── Add Paystack payment tracking ─────────────────────────────
  paystackReference String?   @unique // last successful payment reference
  planId            String? // FK to SubscriptionPlan
  amountNGN         Int? // what was paid
  paidAt            DateTime? // when last payment was confirmed
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @default(now()) @updatedAt

  school  School            @relation(fields: [schoolId], references: [id])
  profile Profile?          @relation("ProfileSubscription", fields: [profileId], references: [id])
  subPlan SubscriptionPlan? @relation(fields: [planId], references: [id])

  @@index([status])
  @@index([currentPeriodEnd])
}

model Invitation {
  id           String    @id @default(uuid())
  email        String
  role         Role
  schoolId     String?
  token        String    @unique
  expiresAt    DateTime
  acceptedAt   DateTime?
  invitedBy    String
  createdAt    DateTime  @default(now())
  curriculumId String

  @@index([token])
  @@index([email])
}

model ActivityLog {
  id          String       @id @default(uuid())
  schoolId    String
  actorId     String
  actorName   String?
  actorRole   String?
  type        ActivityType
  title       String
  description String
  metadata    Json?
  createdAt   DateTime     @default(now())

  school School  @relation(fields: [schoolId], references: [id])
  actor  Profile @relation(fields: [actorId], references: [id])

  @@index([schoolId])
  @@index([actorId])
  @@index([createdAt])
}

model CreditTransaction {
  id          String    @id @default(uuid())
  schoolId    String
  packageId   String
  credits     Int
  amountNGN   Int
  amountKobo  Int
  reference   String    @unique
  status      TxStatus  @default(PENDING)
  initiatedBy String
  paidAt      DateTime?
  createdAt   DateTime  @default(now())

  school School @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
  @@index([reference])
}

model SubscriptionPlan {
  id           String   @id @default(uuid())
  name         String
  slug         String   @unique // 'monthly' | 'termly' | 'annual'
  priceNGN     Int
  priceKobo    Int
  priceUSD     Float
  durationDays Int
  description  String
  features     String[] // array of feature strings
  popular      Boolean  @default(false)
  active       Boolean  @default(true) // soft delete
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  subscriptionTransactions SubscriptionTransaction[]
  subscriptions            Subscription[]

  @@index([active])
  @@index([sortOrder])
}

model SubscriptionTransaction {
  id          String    @id @default(uuid())
  schoolId    String
  planId      String // which plan was purchased
  planName    String // snapshot of plan name at purchase time
  amountNGN   Int // amount paid in naira
  amountKobo  Int // amount in kobo for Paystack
  reference   String    @unique // Paystack reference
  status      TxStatus  @default(PENDING)
  initiatedBy String // profile id of who triggered it
  paidAt      DateTime? // when Paystack confirmed payment
  createdAt   DateTime  @default(now())

  school School           @relation(fields: [schoolId], references: [id])
  plan   SubscriptionPlan @relation(fields: [planId], references: [id])

  @@index([schoolId])
  @@index([status])
  @@index([createdAt])
}

model CreditPackage {
  id          String   @id @default(uuid())
  name        String
  credits     Int
  priceNGN    Int
  priceKobo   Int
  priceUSD    Float
  description String
  popular     Boolean  @default(false)
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([active])
}

enum TxStatus {
  PENDING
  SUCCESS
  FAILED
}

enum ActivityType {
  ASSESSMENT_CREATED
  ASSESSMENT_GRADED
  STUDENT_ENROLLED
  STUDENT_ASSIGNED
  TEACHER_ASSIGNED
  USER_INVITED
  USER_DEACTIVATED
  USER_DELETED
  USER_REACTIVATED
  CLASS_CREATED
  SETTINGS_UPDATED
  CURRICULUM_UPDATED
  TERM_DATES_UPDATED
  WHATSAPP_SENT
  LOGIN
  LOGOUT
  REPORT_GENERATED
}

enum Role {
  SUPER_ADMIN
  SCHOOL_ADMIN
  TEACHER
  STUDENT
  PARENT
  INDIVIDUAL_LEARNER
}

enum AssessmentType {
  TOPIC_BASED
  WEEKLY
  TERMLY
  YEARLY
  MID_TERM
  END_OF_TERM
}

enum EnrollmentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum QuestionCategory {
  PRACTICE // Generated during daily lessons
  EXAM // Generated specifically for high-stakes exams
}

enum ExamStatus {
  DRAFT
  PUBLISHED
  COMPLETED
  ONGOING
  SCHEDULED
}

enum SubmissionStatus {
  SUBMITTED
  GRADED
}

enum LessonStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum OwnershipType {
  GLOBAL
  SCHOOL
}
